import dir
import file
import path
import xml/* as xml

class JUnit
  path_finder: nil

  initialize: ->
    self.path_finder = JUnitPathFinder()

  case_from: suite_name, suite_timestamp, item ->
    status = "passed"
    message = ""
    body = ""
    failure = item.find("failure")
    error_item = item.find("error")
    skipped = item.find("skipped")
    if failure != nil
      status = "failed"
      message = failure.attr("message", "")
      body = failure.text()
    if error_item != nil
      status = "error"
      message = error_item.attr("message", message)
      body = error_item.text()
    if skipped != nil and status == "passed"
      status = "skipped"
      message = skipped.attr("message", "")
      body = skipped.text()
    stdout = ""
    stderr = ""
    system_out = item.find("system-out")
    system_err = item.find("system-err")
    if system_out != nil
      stdout = system_out.text()
    if system_err != nil
      stderr = system_err.text()
    out =
      suite: suite_name
      timestamp: suite_timestamp
      classname: item.attr("classname", "")
      name: item.attr("name", "")
      file: item.attr("file", "")
      line: item.attr("line", "")
      duration: parse_duration(item.attr("time", "0"))
      status: status
      message: message
      body: body
      system_out: stdout
      system_err: stderr
    out

  digit_value: ch ->
    if ch == "0"
      return 0.0
    if ch == "1"
      return 1.0
    if ch == "2"
      return 2.0
    if ch == "3"
      return 3.0
    if ch == "4"
      return 4.0
    if ch == "5"
      return 5.0
    if ch == "6"
      return 6.0
    if ch == "7"
      return 7.0
    if ch == "8"
      return 8.0
    if ch == "9"
      return 9.0
    -1.0

  files: patterns -> path_finder.files(patterns)

  parse: text ->
    cases = []
    root = xml.Xml.parse(text).root()
    if root.name == "testsuite"
      parse_suite(root, cases)
    else
      for child_suite in root.find_all("testsuite")
        parse_suite(child_suite, cases)
    cases

  parse_duration: text ->
    value = 0.0
    fraction = 0.1
    seen_dot = false
    i = 0
    while i < text.byte_len()
      ch = text[i]
      if ch == "."
        seen_dot = true
      else
        digit = digit_value(ch)
        if digit >= 0
          if seen_dot
            value = value + digit * fraction
            fraction = fraction / 10.0
          else
            value = value * 10.0 + digit
      i = i + 1
    value

  parse_file: path_name -> parse(file.File.read(path_name))

  parse_suite: suite, cases ->
    suite_name = suite.attr("name", "")
    suite_timestamp = suite.attr("timestamp", "")
    for item in suite.find_all("testcase")
      cases.push(case_from(suite_name, suite_timestamp, item))

class JUnitPathFinder
  collect_xml: root, out ->
    if root == ""
      root = "."
    for name in dir.Dir.list(root)
      full = path.Path().join([root, name])
      if name.ends_with(".xml")
        out.push(full)
      elseif not name.contains(".")
        collect_xml(full, out)

  files: patterns ->
    out = []
    for pattern in patterns
      if pattern.contains("**/*.xml")
        base = pattern.split("**/*.xml")[0]
        if base.ends_with("/")
          base = slice(base, 0, base.byte_len() - 1)
        collect_xml(base, out)
      else
        out.push(pattern)
    out.sort()

  slice: text, start, finish ->
    out = ""
    i = start
    while i < finish
      out = out + text[i]
      i = i + 1
    out
