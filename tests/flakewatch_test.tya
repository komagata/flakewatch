import file
import os
import unittest/* as *
import flakewatch/*

class FlakewatchTest extends TestCase
  test_cli_accepts_tya_cli_options: ->
    output_path = "tmp/flakewatch-cli-test.html"
    if file.File.exists?(output_path)
      file.File.remove(output_path)
    outcome = flakewatch
      .Application()
      .run(["--junit=tests/fixtures/junit/run1.xml", "--output=" + output_path, "--source-base-url=https://example.test/repo/blob/sha"])
    assert_equal(0, outcome.status, "status")
    html = file.File.read(output_path)
    assert(html.contains("pkg.FlakyTest.alternates"), "report rendered")
    assert(
      html.contains("https://example.test/repo/blob/sha/flaky_test.tya"),
      "source link"
    )

  test_cli_app_reports_option_errors: ->
    outcome = flakewatch.Application().run(["--unknown=true"])
    assert_equal(1, outcome.status, "status")
    assert_equal(
      "ERROR: \"flakewatch\" was called with arguments \"--unknown=true\"",
      outcome.output,
      "error"
    )

  test_cli_history_output_accepts_comma_separated_arrays: ->
    output_path = "tmp/flakewatch-comma-history.jsonl"
    html_path = "tmp/flakewatch-comma-history.html"
    if file.File.exists?(output_path)
      file.File.remove(output_path)
    if file.File.exists?(html_path)
      file.File.remove(html_path)
    outcome = flakewatch
      .Application()
      .run(["--junit=tests/fixtures/junit/run1.xml,tests/fixtures/junit/run2.xml", "--output=" + html_path, "--history-output=" + output_path])
    assert_equal(0, outcome.status, "status")
    jsonl = file.File.read(output_path)
    assert(jsonl.contains("pkg.FlakyTest"), "first file")
    assert(jsonl.contains("pkg.AlwaysFailTest"), "second file")

  test_cli_writes_history_with_environment_defaults: ->
    os.Os.setenv("GITHUB_REPOSITORY", "example/repo")
    output_path = "tmp/flakewatch-env-history.jsonl"
    html_path = "tmp/flakewatch-env-history.html"
    if file.File.exists?(output_path)
      file.File.remove(output_path)
    if file.File.exists?(html_path)
      file.File.remove(html_path)
    outcome = flakewatch
      .Application()
      .run(["--junit=tests/fixtures/junit/run1.xml", "--output=" + html_path, "--history-output=" + output_path])
    os.Os.unsetenv("GITHUB_REPOSITORY")
    assert_equal(0, outcome.status, "status")
    html = file.File.read(html_path)
    assert(html.contains("pkg.FlakyTest.alternates"), "report")
    jsonl = file.File.read(output_path)
    assert(jsonl.contains("\"repo\":\"example/repo\""), "repo")
    assert(jsonl.contains("\"workflow\":\"local\""), "fallback")

  test_command_help_uses_tya_cli_application: ->
    outcome = flakewatch.Application().run(["--help"])
    assert_equal(0, outcome.status, "status")
    assert(outcome.output.contains("Command:\n  flakewatch"), "command")
    assert(
      outcome.output.contains("--junit # JUnit XML glob or file path"),
      "junit option"
    )
    assert(
      outcome.output.contains("Examples:\n  flakewatch --junit"),
      "example"
    )

  test_html_report_links_to_source_files: ->
    html = flakewatch
      .Report()
      .render({ junit: ["tests/fixtures/junit/run1.xml"], source_base_url: "https://github.com/example/app/blob/abc123" })
    self.assert(
      html.contains(
        "https://github.com/example/app/blob/abc123/flaky_test.tya#L8"
      ),
      "source link"
    )
    self.assert(
      html.contains(
        "https://github.com/example/app/blob/abc123/tests/fixtures/source/user_events_test.rb#L2"
      ),
      "inferred source line"
    )

  test_html_report_ranks_tests_without_time_as_zero_seconds: ->
    html = flakewatch
      .Report()
      .render({ junit: ["tests/fixtures/junit/no_time.xml"] })
    assert(html.contains("<h2>Slow Tests</h2>"), "slow section")
    assert(html.contains("pkg.NoTimeTest.still_ranks"), "zero duration test")
    assert(html.contains("<td class=\"num\">0</td>"), "zero seconds")
    assert(html.contains("<strong>0</strong>slow tests"), "slow count")

  test_html_report_renders_flaky_and_slow_tests_without_database: ->
    html = flakewatch
      .Report()
      .render({ junit: ["tests/fixtures/junit/**/*.xml"] })
    assert(html.contains("<h2>Flaky Tests</h2>"), "flaky section")
    assert(html.contains("<h2>Healed Candidates</h2>"), "healed section")
    assert(html.contains("<h2>Failing Tests</h2>"), "failing section")
    assert(html.contains("<h2>Slow Tests</h2>"), "slow section")
    self.assert(
      html.contains("data-sort=\"number\">Failures</th>"),
      "sortable failure count"
    )
    self.assert(
      html.contains("data-sort=\"number\">Fail</th>"),
      "sortable fail count"
    )
    self.assert(
      html.contains("data-sort=\"number\">Max seconds</th>"),
      "sortable max seconds"
    )
    assert(html.contains("querySelectorAll('th[data-sort]')"), "sort script")
    assert(html.contains("<style>"), "embedded style")
    self.assert(
      html.contains(".metric strong") and html.contains("font-size: 28px"),
      "metric style"
    )
    assert(html.contains("pkg.FlakyTest.alternates"), "flaky test")
    assert(html.contains("pkg.HealedTest.recovers"), "healed test")
    assert(html.contains("10 passed"), "healed recent status")
    assert(html.contains("pkg.AlwaysFailTest.fails"), "slow test")
    assert(html.contains("<strong>6</strong>slow tests"), "slow count")

  test_jsonl_history_extends_html_observations: ->
    history_path = "tmp/flakewatch-history.jsonl"
    if file.File.exists?(history_path)
      file.File.remove(history_path)
    flakewatch
      .History()
      .export_file({ output: history_path, junit: ["tests/fixtures/junit/run1.xml"], repo: "repo", workflow: "ci", run_id: "1", run_attempt: "1", job: "test", sha: "a", branch: "main", event: "push" })
    html = flakewatch
      .Report()
      .render({ junit: ["tests/fixtures/junit/run2.xml"], history: [history_path], source_base_url: "", source_root: "." })
    self.assert(
      html.contains("pkg.FlakyTest.alternates"),
      "history creates flake signal"
    )

  test_junit_files_are_sorted_for_stable_matrix_reports: ->
    files = flakewatch
      .JUnit()
      .files(["tests/fixtures/junit/run2.xml", "tests/fixtures/junit/run1.xml"])
    assert_equal("tests/fixtures/junit/run1.xml", files[0], "first file")
    assert_equal("tests/fixtures/junit/run2.xml", files[1], "second file")
    rows = flakewatch
      .Report()
      .junit_rows(["tests/fixtures/junit/run2.xml", "tests/fixtures/junit/run1.xml"])
    found = false
    for row in rows
      if row["name"] == "pkg.FlakyTest.alternates"
        found = true
        assert_equal("failed", row["last_status"], "last status")
    assert(found, "flaky row")

  test_junit_parse_single_quoted_attributes: ->
    cases = flakewatch
      .JUnit()
      .parse_file("tests/fixtures/junit/single_quote.xml")
    assert_equal(1, cases.len(), "case count")
    assert_equal("pkg", cases[0]["suite"], "suite")
    assert_equal("2026-05-25T00:00:00Z", cases[0]["timestamp"], "timestamp")
    assert_equal("pkg.SingleQuoteTest", cases[0]["classname"], "classname")
    assert_equal("reads_single_quoted_attrs", cases[0]["name"], "name")
    assert_equal("single_quote_test.tya", cases[0]["file"], "file")
    assert_equal("9", cases[0]["line"], "line")
    assert_equal(1.23, cases[0]["duration"], "duration")

  test_junit_parse_testsuite_and_testsuites: ->
    one = flakewatch.JUnit().parse_file("tests/fixtures/junit/run1.xml")
    two = flakewatch.JUnit().parse_file("tests/fixtures/junit/run2.xml")
    assert_equal(4, one.len(), "testsuite")
    assert_equal(3, two.len(), "testsuites")
    assert_equal("failed", one[1]["status"], "failure")
    assert_equal("stack trace", one[1]["body"], "cdata")
    assert_equal("stdout text", one[1]["system_out"], "stdout")
    assert_equal("stderr text", one[1]["system_err"], "stderr")
    assert_equal("skipped", one[2]["status"], "skipped")
    assert_equal("error", two[2]["status"], "error")

  test_root_help_uses_tya_cli_application: ->
    outcome = flakewatch.Application().run([])
    assert_equal(0, outcome.status, "status")
    assert(
      outcome.output.contains("Usage:\n  flakewatch --junit=PATH"),
      "usage"
    )
    assert(outcome.output.contains("--history-output"), "history output")
