import unittest
import flakewatch

class FlakewatchTest extends TestCase
  test_junit_parse_testsuite_and_testsuites = ->
    one = JUnit.parse_file("tests/fixtures/junit/run1.xml")
    two = JUnit.parse_file("tests/fixtures/junit/run2.xml")
    self.assert_equal(3, one.len(), "testsuite")
    self.assert_equal(3, two.len(), "testsuites")
    self.assert_equal("failed", one[1]["status"], "failure")
    self.assert_equal("stack trace", one[1]["body"], "cdata")
    self.assert_equal("stdout text", one[1]["system_out"], "stdout")
    self.assert_equal("stderr text", one[1]["system_err"], "stderr")
    self.assert_equal("skipped", one[2]["status"], "skipped")
    self.assert_equal("error", two[2]["status"], "error")

  test_ingest_is_idempotent_and_scores_flakes = ->
    db_path = "tmp/flakewatch-test.sqlite3"
    db = Database.open(db_path)
    db.close()
    Ingest.run({ db: db_path, junit: ["tests/fixtures/junit/run1.xml"], repo: "repo", workflow: "ci", run_id: "1", run_attempt: "1", job: "test", sha: "a", branch: "main", event: "push", os: "Linux", runtime: "tya", started_at: "" })
    Ingest.run({ db: db_path, junit: ["tests/fixtures/junit/run1.xml"], repo: "repo", workflow: "ci", run_id: "1", run_attempt: "1", job: "test", sha: "a", branch: "main", event: "push", os: "Linux", runtime: "tya", started_at: "" })
    Ingest.run({ db: db_path, junit: ["tests/fixtures/junit/run2.xml"], repo: "repo", workflow: "ci", run_id: "2", run_attempt: "1", job: "test", sha: "b", branch: "main", event: "push", os: "Linux", runtime: "tya", started_at: "" })
    db = Database.open(db_path)
    results = db.query("select count(*) as n from test_results")[0]["n"]
    self.assert_equal(6, results, "idempotent")
    report = Report.render(db, "github-summary")
    self.assert(report.contains("FlakyTest.alternates"), "flaky ranked")
    db.close()
