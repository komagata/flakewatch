import unittest
import file as file
import flakewatch

class FlakewatchTest extends TestCase
  test_junit_parse_testsuite_and_testsuites = ->
    one = JUnit.parse_file("tests/fixtures/junit/run1.xml")
    two = JUnit.parse_file("tests/fixtures/junit/run2.xml")
    self.assert_equal(4, one.len(), "testsuite")
    self.assert_equal(3, two.len(), "testsuites")
    self.assert_equal("failed", one[1]["status"], "failure")
    self.assert_equal("stack trace", one[1]["body"], "cdata")
    self.assert_equal("stdout text", one[1]["system_out"], "stdout")
    self.assert_equal("stderr text", one[1]["system_err"], "stderr")
    self.assert_equal("skipped", one[2]["status"], "skipped")
    self.assert_equal("error", two[2]["status"], "error")

  test_ingest_is_idempotent_and_scores_flakes = ->
    db_path = "tmp/flakewatch-test.sqlite3"
    if file.File.exists?(db_path)
      file.File.remove(db_path)
    db = Database.open(db_path)
    db.close()
    Ingest.run({ db: db_path, junit: ["tests/fixtures/junit/run1.xml"], repo: "repo", workflow: "ci", run_id: "1", run_attempt: "1", job: "test", sha: "a", branch: "main", event: "push", os: "Linux", runtime: "tya", started_at: "" })
    Ingest.run({ db: db_path, junit: ["tests/fixtures/junit/run1.xml"], repo: "repo", workflow: "ci", run_id: "1", run_attempt: "1", job: "test", sha: "a", branch: "main", event: "push", os: "Linux", runtime: "tya", started_at: "" })
    Ingest.run({ db: db_path, junit: ["tests/fixtures/junit/run2.xml"], repo: "repo", workflow: "ci", run_id: "2", run_attempt: "1", job: "test", sha: "b", branch: "main", event: "push", os: "Linux", runtime: "tya", started_at: "" })
    db = Database.open(db_path)
    results = db.query("select count(*) as n from test_results")[0]["n"]
    self.assert_equal(7, results, "idempotent")
    report = Report.render(db, "github-summary")
    self.assert(report.contains("FlakyTest.alternates"), "flaky ranked")
    db.close()

  test_html_report_renders_flaky_and_slow_tests_without_database = ->
    html = Report.html_from_junit(["tests/fixtures/junit/**/*.xml"])
    self.assert(html.contains("<h2>Flaky Tests</h2>"), "flaky section")
    self.assert(html.contains("<h2>Healed Candidates</h2>"), "healed section")
    self.assert(html.contains("<h2>Slow Tests</h2>"), "slow section")
    self.assert(html.contains("data-sort=\"number\">Fail</th>"), "sortable fail count")
    self.assert(html.contains("data-sort=\"number\">Max seconds</th>"), "sortable max seconds")
    self.assert(html.contains("querySelectorAll('th[data-sort]')"), "sort script")
    self.assert(html.contains("pkg.FlakyTest.alternates"), "flaky test")
    self.assert(html.contains("pkg.HealedTest.recovers"), "healed test")
    self.assert(html.contains("10 passed"), "healed recent status")
    self.assert(html.contains("pkg.AlwaysFailTest.fails"), "slow test")

  test_html_report_links_to_source_files = ->
    html = Report.html_from_junit_with_source(["tests/fixtures/junit/run1.xml"], "https://github.com/example/app/blob/abc123")
    self.assert(html.contains("https://github.com/example/app/blob/abc123/flaky_test.tya#L8"), "source link")
    self.assert(html.contains("https://github.com/example/app/blob/abc123/tests/fixtures/source/user_events_test.rb#L2"), "inferred source line")
